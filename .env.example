# ===========================
# STUDCASH ENVIRONMENT VARIABLES
# ===========================
# IMPORTANT: This is an example file. Copy it to .env and fill with YOUR actual values.
# NEVER commit real credentials to version control!

# ===========================
# EMAIL CONFIGURATION (SMTP)
# ===========================
# For Gmail: Generate an "App Password" from Google Account Security
# Link: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-16-chars

# ===========================
# JWT CONFIGURATION
# ===========================
# JWT Secret: Use a strong random string for production
# Expiration: in milliseconds (86400000 = 24 hours)
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRATION_MS=86400000

# ===========================
# AI & OCR CONFIGURATION (GEMINI)
# ===========================
# Google Gemini API for document extraction (KYC, BAC, transcripts)
# Get API key from: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ===========================
# CLOUD STORAGE CONFIGURATION (CLOUDINARY)
# ===========================
# Cloudinary for document and image storage
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================
# DATABASE CONFIGURATION
# ===========================
# PostgreSQL connection details
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/studcash
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your-db-password

# ===========================
# SERVER CONFIGURATION
# ===========================
# SERVER_PORT=8080
# SERVER_SERVLET_CONTEXT_PATH=/api
